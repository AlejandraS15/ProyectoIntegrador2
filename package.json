{
  "name": "proyectointegrador2",
  "version": "1.0.0",
  "description": "Este es el primer commit",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:css": "tailwindcss -i ./src/assets/css/input.css -o ./public/css/styles.css --watch",
    "build": "tsc -p tsconfig.json && node scripts/copy-static.mjs && npm run build:css",
    "build:css": "tailwindcss -i ./src/assets/css/input.css -o ./dist/public/css/styles.css --minify",
    "start": "node dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlejandraS15/ProyectoIntegrador2.git"
  },
