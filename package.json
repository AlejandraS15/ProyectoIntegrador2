  "type": "module",
  "bugs": {
    "url": "https://github.com/AlejandraS15/ProyectoIntegrador2/issues"
  },
  "homepage": "https://github.com/AlejandraS15/ProyectoIntegrador2#readme",
  "dependencies": {
    "ejs": "^5.0.1",
    "express": "^5.2.1",
    "express-ejs-layouts": "^2.5.1"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.6",
    "@types/express-ejs-layouts": "^2.5.4",
    "@types/node": "^25.5.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
