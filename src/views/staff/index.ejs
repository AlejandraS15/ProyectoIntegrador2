<!-- HERO STAFF -->
<section class="page-hero relative overflow-hidden bg-dental-ivory pt-32 pb-16">
  <div class="section-container text-center" data-aos="fade-up">
    <span class="mb-2 block text-sm font-bold uppercase tracking-widest text-dental-brown">
      <%= isEnglish ? "Our Specialists" : "Nuestros Especialistas" %>
    </span>
    <h1 class="mb-6 text-5xl text-dental-dark">
      <%= isEnglish ? "Meet the Main Medical Team" : "Conoce al Equipo Médico Principal" %>
    </h1>
    <p class="mx-auto max-w-3xl text-lg text-dental-brown/80">
      <%= isEnglish
        ? "Three doctors lead Dental Expertos with clinical precision, aesthetic sensitivity and warm care from the very first consultation."
        : "Tres doctoras lideran Dental Expertos con precisión clínica, sensibilidad estética y un trato humano que se siente desde la primera consulta." %>
    </p>
  </div>
</section>

<!-- STAFF GRID -->
<section class="bg-dental-cream py-16 relative">
  <div class="section-container">
    <div class="mx-auto grid max-w-6xl gap-8 md:grid-cols-2 xl:grid-cols-3">
      <% doctors.forEach((doctor, index) => { %>
        <article class="doctor-card group" data-aos="fade-up" data-aos-delay="<%= 100 + index * 80 %>">
          <button type="button" class="doctor-card__trigger" data-modal-target="modal-<%= doctor.id %>" aria-label="<%= isEnglish ? 'View full profile for ' : 'Ver perfil completo de ' %><%= doctor.name %>">
            <div class="doctor-card__media">
              <img
                src="<%= doctor.image %>"
                alt="<%= doctor.name %>"
                class="doctor-card__image <%= doctor.imageClass %>"
                onerror="this.onerror=null;this.src='/img/placeholders/dental-avatar.svg';"
              />
              <div class="doctor-card__overlay">
                <div class="doctor-card__overlay-content">
                  <span class="doctor-card__overlay-title"><%= isEnglish ? "View Career" : "Ver Trayectoria" %></span>
                  <p class="doctor-card__overlay-copy"><%= isEnglish ? "Click for details" : "Click para detalles" %></p>
                </div>
              </div>
            </div>
            <div class="p-8 text-left bg-white transition-colors group-hover:bg-dental-ivory/30">
              <h2 class="font-serif text-2xl text-dental-dark mb-1 group-hover:text-dental-gold transition-colors"><%= doctor.name %></h2>
              <p class="text-xs font-bold uppercase tracking-widest text-dental-gold mb-4"><%= isEnglish ? doctor.specialtyEn : doctor.specialtyEs %></p>
              <p class="text-dental-brown/70 leading-relaxed mb-6 line-clamp-3">
                <%= isEnglish ? doctor.shortEn : doctor.shortEs %>
              </p>
              <span class="inline-flex items-center text-sm font-medium text-dental-gold group-hover:text-dental-brown transition-colors">
                <%= isEnglish ? "View full profile" : "Ver perfil completo" %>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-2 group-hover:translate-x-1 transition-transform"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
              </span>
            </div>
          </button>
        </article>
      <% }) %>
    </div>
  </div>
</section>

<!-- MODALS -->
<div id="modal-container">
  <% doctors.forEach((doctor) => { %>
    <div id="modal-<%= doctor.id %>" class="modal-backdrop" role="dialog" aria-modal="true" aria-hidden="true" aria-labelledby="modal-<%= doctor.id %>-title">
      <div class="modal-content mx-4 max-h-[90vh] overflow-y-auto">
        <button type="button" data-modal-close="modal-<%= doctor.id %>" class="modal-close-btn shadow-md hover:shadow-lg" aria-label="<%= isEnglish ? 'Close modal' : 'Cerrar modal' %> <%= doctor.name %>">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg>
        </button>
        <div class="md:flex">
          <div class="md:w-2/5 modal-profile__image-wrap">
            <img src="<%= doctor.image %>" class="modal-profile__image modal-profile__image--<%= doctor.id %>" onerror="this.onerror=null;this.src='/img/placeholders/dental-avatar.svg';" alt="<%= isEnglish ? 'Profile for ' : 'Perfil ' %><%= doctor.name %>">
          </div>
          <div class="md:w-3/5 p-8 md:p-12 bg-white">
            <span class="inline-block px-3 py-1 rounded-full bg-dental-cream text-dental-brown text-xs font-bold tracking-widest uppercase mb-4"><%= isEnglish ? doctor.specialtyEn : doctor.specialtyEs %></span>
            <h2 id="modal-<%= doctor.id %>-title" class="font-serif text-3xl md:text-4xl text-dental-dark mb-6"><%= doctor.name %></h2>
            <div class="prose prose-brown max-w-none text-dental-brown/80 space-y-6 max-h-[24rem] overflow-y-auto pr-2">
              <p class="text-lg leading-relaxed font-light italic border-l-4 border-dental-brown pl-4 bg-dental-ivory/20 py-2">
                "<%= isEnglish ? doctor.quoteEn : doctor.quoteEs %>"
              </p>
              <p><%= isEnglish ? doctor.bioEn : doctor.bioEs %></p>
              <div class="profile-section">
                <h3 class="profile-section__title"><%= isEnglish ? doctor.sectionTitleEn : doctor.sectionTitleEs %></h3>
                <ul class="profile-section__list">
                  <% (isEnglish ? doctor.bulletsEn : doctor.bulletsEs).forEach((item) => { %>
                    <li><%= item %></li>
                  <% }) %>
                </ul>
              </div>
            </div>
            <div class="mt-8 pt-6 border-t border-gray-100 flex justify-end">
              <a href="<%= whatsappUrl(isEnglish ? `Hello Dental Expertos, I would like to book an appointment with ${doctor.name}.` : `Hola Dental Expertos, quisiera agendar una cita con ${doctor.name}.`) %>" target="_blank" class="inline-flex items-center px-6 py-3 rounded-full bg-dental-dark text-dental-ivory font-medium hover:bg-dental-brown transition-colors shadow-lg">
                <%= isEnglish ? "Book Appointment" : "Agendar Cita" %>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% }) %>
</div>
