<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />    
    <%- include("../partials/seo-meta") %>
    <link rel="stylesheet" href="/css/styles.css" />
    <!-- AOS Animate on scroll -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
  </head>
  <body class="min-h-screen bg-dental-ivory text-dental-dark antialiased selection:bg-dental-brown selection:text-dental-ivory">
    <%- include("../partials/header") %>
    
    <main class="w-full">
      <%- body %>
    </main>

    <%- include("../partials/footer") %>

    <!-- Floating WhatsApp Button -->
    <a href="https://wa.me/573153374433?text=Hola%20Dental%20Expertos%2C%20quiero%20agendar%20una%20cita" target="_blank" rel="noopener noreferrer"
        class="fixed bottom-8 right-8 z-50 bg-[#25D366] text-white p-4 rounded-full shadow-2xl hover:scale-110 transition-transform flex items-center justify-center">
      <i data-lucide="message-circle" class="w-7 h-7"></i>
    </a>

    <!-- Scripts -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
      // Initialize Icons
      lucide.createIcons();
      // Initialize AOS Animations
      AOS.init({
        once: true,
        offset: 50,
        duration: 800,
        easing: 'ease-out-cubic',
      });
      // Before & After slider logic
      document.querySelectorAll(".before-after").forEach((container) => {
        const slider = container.querySelector(".before-after__slider");
        const panels = container.querySelectorAll("[data-inline-style]");

        panels.forEach((panel) => {
          const styleText = panel.getAttribute("data-inline-style");
          if (styleText) {
            panel.style.cssText = styleText;
          }
        });

        if (!(slider instanceof HTMLInputElement)) {
          return;
        }

        const updatePosition = (value) => {
          const numericValue = Number(value);
          const clamped = Number.isFinite(numericValue)
            ? Math.min(100, Math.max(0, numericValue))
            : 50;

          container.style.setProperty("--ba-position", `${clamped}%`);
        };

        updatePosition(slider.value);
        slider.addEventListener("input", (event) => {
          updatePosition(event.currentTarget.value);
        });
      });
    </script>
</html>
