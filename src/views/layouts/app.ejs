<!DOCTYPE html>
<html lang="<%= language %>" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />    
    <%- include("../partials/seo-meta") %>
    <link rel="stylesheet" href="/css/styles.css" />
    <!-- AOS Animate on scroll -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
  </head>
  <body class="min-h-screen overflow-x-hidden bg-dental-ivory text-dental-dark antialiased selection:bg-dental-brown selection:text-dental-ivory">
    <%- include("../partials/header") %>
    
    <main class="w-full">
      <%- body %>
    </main>

    <%- include("../partials/footer") %>

    <!-- Floating WhatsApp Button -->
    <a href="<%= whatsappUrl() %>" target="_blank" rel="noopener noreferrer"
        class="fixed bottom-8 right-8 z-50 hidden bg-[#25D366] text-white p-4 rounded-full shadow-2xl transition-transform hover:scale-110 sm:flex items-center justify-center">
      <i data-lucide="message-circle" class="w-7 h-7"></i>
    </a>

    <!-- Scripts -->
    <script defer src="https://unpkg.com/lucide@latest"></script>
    <script defer src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script defer src="/js/main.js"></script>
  </body>
</html>
