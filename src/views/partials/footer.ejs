<footer class="bg-dental-cream pt-24 pb-12 border-t border-dental-beige">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16">
      <div class="space-y-4">
        <a href="<%= localizedPath('/') %>" class="flex items-center gap-2 group">
          <div class="w-10 h-10 bg-dental-dark rounded-full flex items-center justify-center transition-transform group-hover:scale-105">
            <i data-lucide="sparkles" class="text-dental-beige w-5 h-5"></i>
          </div>
          <div class="flex flex-col leading-none">
            <span class="font-serif font-bold text-xl tracking-wide text-dental-dark">Dental Expertos</span>
            <span class="text-[10px] tracking-widest text-dental-brown uppercase"><%= t("brand.tagline") %></span>
          </div>
        </a>
        <p class="text-dental-brown/80 text-sm leading-relaxed max-w-xs mt-4">
          <%= isEnglish
            ? "We transform smiles with advanced technology and a warm, artistic approach."
            : "Transformamos sonrisas con tecnología de vanguardia y un enfoque humano y artístico." %>
        </p>
      </div>

      <div>
        <h4 class="font-serif text-lg text-dental-dark mb-6"><%= t("footer.quickLinks") %></h4>
        <ul class="space-y-3">
          <li><a href="<%= localizedPath('/') %>" class="text-sm text-dental-brown/80 hover:text-dental-dark transition-colors"><%= isEnglish ? 'Home' : 'Inicio' %></a></li>
          <li><a href="<%= localizedPath('/nosotros') %>" class="text-sm text-dental-brown/80 hover:text-dental-dark transition-colors"><%= t("footer.about") %></a></li>
          <li><a href="<%= localizedPath('/tratamientos') %>" class="text-sm text-dental-brown/80 hover:text-dental-dark transition-colors"><%= t("footer.treatments") %></a></li>
          <li><a href="<%= localizedPath('/resultados') %>" class="text-sm text-dental-brown/80 hover:text-dental-dark transition-colors"><%= isEnglish ? 'Results' : 'Resultados' %></a></li>
          <li><a href="<%= localizedPath('/equipo') %>" class="text-sm text-dental-brown/80 hover:text-dental-dark transition-colors"><%= t("footer.staff") %></a></li>
          <li><a href="<%= localizedPath('/contacto') %>" class="text-sm text-dental-brown/80 hover:text-dental-dark transition-colors"><%= t("footer.contact") %></a></li>
        </ul>
      </div>

      <div>
        <h4 class="font-serif text-lg text-dental-dark mb-6"><%= t("footer.contactTitle") %></h4>
        <ul class="space-y-4">
          <li class="flex items-start gap-3 text-sm text-dental-brown/80">
            <i data-lucide="map-pin" class="w-5 h-5 shrink-0 text-dental-dark"></i>
            <a href="<%= googleMapsUrl %>" target="_blank" rel="noopener noreferrer" class="hover:text-dental-dark transition-colors">
              Avenida Guayabal, <%= isEnglish ? "near the end of the 10th Street bridge" : "antes de finalizar el puente de la 10" %><br/>Cra. 52 # 07-115, Guayabal
            </a>
          </li>
          <li class="flex items-center gap-3 text-sm text-dental-brown/80">
            <i data-lucide="phone" class="w-5 h-5 shrink-0 text-dental-dark"></i>
            <span>+57 3008938020</span>
          </li>
          <li class="flex items-center gap-3 text-sm text-dental-brown/80">
            <i data-lucide="mail" class="w-5 h-5 shrink-0 text-dental-dark"></i>
            <span>dentalexpertos@hotmail.com</span>
          </li>
        </ul>
      </div>

      <div>
        <h4 class="font-serif text-lg text-dental-dark mb-6"><%= t("footer.schedule") %></h4>
        <ul class="space-y-3 text-sm text-dental-brown/80">
          <li class="flex justify-between border-b border-dental-beige/50 pb-2">
            <span><%= t("footer.weekdays") %></span>
            <span class="text-dental-dark font-medium">8:00 a.m. - 7:00 p.m.</span>
          </li>
          <li class="flex justify-between border-b border-dental-beige/50 pb-2">
            <span><%= t("footer.saturdays") %></span>
            <span class="text-dental-dark font-medium">8:00 a.m. - 3:00 p.m.</span>
          </li>
          <li class="flex justify-between pb-2">
            <span><%= isEnglish ? "Sundays and holidays" : "Domingos y festivos" %></span>
            <span class="text-dental-brown/60"><%= t("footer.closed") %></span>
          </li>
        </ul>
      </div>
    </div>

    <div class="pt-8 border-t border-dental-beige flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-dental-brown/60">
      <p><%= t("footer.rights") %></p>
      <div class="flex gap-6">
        <a href="#" class="hover:text-dental-dark transition-colors"><%= t("footer.privacy") %></a>
        <a href="#" class="hover:text-dental-dark transition-colors"><%= t("footer.terms") %></a>
      </div>
    </div>
  </div>
</footer>
