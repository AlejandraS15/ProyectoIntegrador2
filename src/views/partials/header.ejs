<header id="main-nav" class="fixed top-0 left-0 w-full z-50 transition-all duration-500 bg-transparent py-4">
  <div class="max-w-7xl mx-auto px-6 flex justify-between items-center">
    <a href="<%= localizedPath('/') %>" class="flex items-center gap-2 group">
      <div class="w-10 h-10 bg-dental-dark rounded-full flex items-center justify-center transition-transform duration-300 group-hover:scale-105 group-hover:rotate-6">
        <i data-lucide="sparkles" class="text-dental-beige w-5 h-5"></i>
      </div>
      <div class="flex flex-col leading-none">
        <span class="font-serif font-bold text-xl tracking-wide text-dental-dark">Dental Expertos</span>
        <span class="text-[10px] tracking-widest text-dental-brown uppercase"><%= t("brand.tagline") %></span>
      </div>
    </a>

    <!-- Desktop Menu -->
    <nav class="hidden md:flex items-center gap-8" aria-label="<%= isEnglish ? 'Main navigation' : 'Navegación principal' %>">
      <a href="<%= localizedPath('/') %>" class="relative text-sm font-medium text-dental-dark transition-colors after:absolute after:-bottom-2 after:left-0 after:h-px after:w-0 after:bg-dental-brown after:transition-all after:duration-300 hover:text-dental-brown hover:after:w-full"><%= t("nav.home") %></a>
      <a href="<%= localizedPath('/nosotros') %>" class="relative text-sm font-medium text-dental-dark transition-colors after:absolute after:-bottom-2 after:left-0 after:h-px after:w-0 after:bg-dental-brown after:transition-all after:duration-300 hover:text-dental-brown hover:after:w-full"><%= t("nav.about") %></a>
      <a href="<%= localizedPath('/tratamientos') %>" class="relative text-sm font-medium text-dental-dark transition-colors after:absolute after:-bottom-2 after:left-0 after:h-px after:w-0 after:bg-dental-brown after:transition-all after:duration-300 hover:text-dental-brown hover:after:w-full"><%= t("nav.treatments") %></a>
      <a href="<%= localizedPath('/resultados') %>" class="relative text-sm font-medium text-dental-dark transition-colors after:absolute after:-bottom-2 after:left-0 after:h-px after:w-0 after:bg-dental-brown after:transition-all after:duration-300 hover:text-dental-brown hover:after:w-full"><%= t("nav.results") %></a>
      <a href="<%= localizedPath('/equipo') %>" class="relative text-sm font-medium text-dental-dark transition-colors after:absolute after:-bottom-2 after:left-0 after:h-px after:w-0 after:bg-dental-brown after:transition-all after:duration-300 hover:text-dental-brown hover:after:w-full"><%= t("nav.staff") %></a>
      <a href="<%= alternateLanguageUrl %>" class="rounded-full border border-dental-beige bg-white/70 px-3 py-2 text-xs font-bold uppercase tracking-widest text-dental-brown transition-colors hover:bg-dental-cream">
        <%= isEnglish ? "ES" : "EN" %>
      </a>
      <a href="<%= localizedPath('/contacto') %>" class="premium-button premium-button--dark px-6 py-2.5 text-sm">
        <%= t("nav.cta") %>
      </a>
    </nav>

    <!-- Mobile Toggle -->
    <button id="mobile-menu-btn" class="md:hidden rounded-full border border-dental-beige/70 bg-white/70 p-2 text-dental-dark shadow-sm backdrop-blur" type="button" aria-controls="mobile-menu" aria-expanded="false" aria-label="<%= t("nav.toggle") %>">
      <i data-lucide="menu" id="menu-icon" class="w-6 h-6"></i>
      <i data-lucide="x" id="close-icon" class="w-6 h-6 hidden"></i>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden absolute top-full left-0 w-full bg-dental-ivory/95 border-t border-dental-beige premium-shadow overflow-hidden backdrop-blur-xl transition-all duration-300">
    <nav class="flex flex-col px-6 py-5 gap-4" aria-label="<%= isEnglish ? 'Mobile navigation' : 'Navegación móvil' %>">
      <a href="<%= localizedPath('/') %>" class="text-lg font-serif text-dental-dark py-2 border-b border-dental-beige/30"><%= t("nav.home") %></a>
      <a href="<%= localizedPath('/nosotros') %>" class="text-lg font-serif text-dental-dark py-2 border-b border-dental-beige/30"><%= t("nav.about") %></a>
      <a href="<%= localizedPath('/tratamientos') %>" class="text-lg font-serif text-dental-dark py-2 border-b border-dental-beige/30"><%= t("nav.treatments") %></a>
      <a href="<%= localizedPath('/resultados') %>" class="text-lg font-serif text-dental-dark py-2 border-b border-dental-beige/30"><%= t("nav.results") %></a>
      <a href="<%= localizedPath('/equipo') %>" class="text-lg font-serif text-dental-dark py-2 border-b border-dental-beige/30"><%= t("nav.staff") %></a>
      <a href="<%= alternateLanguageUrl %>" class="text-sm font-bold uppercase tracking-widest text-dental-brown py-2 border-b border-dental-beige/30"><%= isEnglish ? "Español" : "English" %></a>
      <a href="<%= localizedPath('/contacto') %>" class="premium-button premium-button--dark mt-4 px-6 py-3 text-base">
        <%= t("nav.cta") %>
      </a>
    </nav>
  </div>
</header>
