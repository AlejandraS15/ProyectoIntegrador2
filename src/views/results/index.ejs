<section class="pt-32 pb-12 bg-dental-ivory">
  <div class="section-container text-center" data-aos="fade-up">
    <span class="mb-3 block text-xs font-semibold uppercase tracking-[0.18em] text-dental-brown">
      Galería de Transformaciones
    </span>
    <h1 class="text-4xl sm:text-5xl text-dental-dark">Diseños de Sonrisa Realizados</h1>
    <p class="mx-auto mt-5 max-w-3xl text-base leading-relaxed text-dental-brown/80 sm:text-lg">
      Cada caso representa la dedicación de nuestro equipo por crear sonrisas armónicas, naturales y transformadoras. Desliza para ver el antes y después de nuestros trabajos.
    </p>
  </div>
</section>

<section class="pb-20 bg-dental-cream">
  <div class="section-container">
    <div class="mx-auto grid max-w-7xl gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
      <% cases.forEach((c, index) => { %>
        <article class="rounded-[1.7rem] border border-dental-beige/60 bg-white p-4 premium-shadow transition-all hover:-translate-y-1" data-aos="fade-up" data-aos-delay="<%= Math.min(index * 60, 300) %>">
          <%- include("../partials/beforeAfter", {
            after: c.after,
            afterLabel: c.afterLabel,
            before: c.before,
            beforeLabel: c.beforeLabel,
            compact: true,
            image: c.image
          }) %>

          <div class="mt-4">
            <h2 class="text-lg text-dental-dark"><%= c.title %></h2>
            <p class="mt-2 text-sm leading-relaxed text-dental-brown/75"><%= c.description %></p>
          </div>
        </article>
      <% }) %>
    </div>
  </div>
</section>